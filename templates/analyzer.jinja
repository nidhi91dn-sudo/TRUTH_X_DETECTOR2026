<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Message Analyzer | Truth-X Detector</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
.analyzer-grid {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 24px;
  align-items: start;
}

@media (max-width: 960px) {
  .analyzer-grid { grid-template-columns: 1fr; }
}

textarea {
  width: 100%;
  min-height: 180px;
  padding: 16px;
  background: rgba(0,0,0,0.35);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px;
  color: #fff;
  font-size: 14px;
  font-family: 'Inter', sans-serif;
  resize: vertical;
  outline: none;
  transition: 0.25s;
  line-height: 1.6;
}

textarea:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(0,217,255,0.12);
}

textarea::placeholder { color: #3d5a7a; }

.word-tag {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 12px;
  border-radius: 20px;
  background: rgba(255,75,110,0.1);
  border: 1px solid rgba(255,75,110,0.3);
  color: var(--red);
  font-size: 12px;
  font-weight: 600;
  margin: 4px;
}

.warn-tag {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 12px;
  border-radius: 20px;
  background: rgba(245,197,24,0.1);
  border: 1px solid rgba(245,197,24,0.3);
  color: var(--yellow);
  font-size: 12px;
  font-weight: 600;
  margin: 4px;
}

.chart-box {
  width: 200px;
  height: 200px;
  margin: 0 auto;
}

.pie-label {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-top: 14px;
  font-size: 13px;
}

.pie-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  display: inline-block;
  margin-right: 5px;
}

/* ───────── LANGUAGE MODAL ───────── */
#lang-modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.65);
  backdrop-filter: blur(6px);
  z-index: 9999;
  justify-content: center;
  align-items: center;
}
#lang-modal-overlay.active { display: flex; }

#lang-modal {
  background: linear-gradient(135deg, rgba(10,20,40,0.97), rgba(5,15,30,0.97));
  border: 1px solid rgba(0,217,255,0.18);
  border-radius: 20px;
  padding: 32px 28px 26px;
  width: 420px;
  max-width: 95vw;
  box-shadow: 0 30px 80px rgba(0,0,0,0.6), 0 0 40px rgba(0,217,255,0.07);
  animation: modalSlideIn 0.3s ease;
}

@keyframes modalSlideIn {
  from { opacity:0; transform: translateY(-30px) scale(0.96); }
  to   { opacity:1; transform: translateY(0) scale(1); }
}

#lang-modal h3 {
  font-size: 18px;
  font-weight: 800;
  color: #fff;
  margin-bottom: 6px;
}
#lang-modal p {
  font-size: 13px;
  color: var(--muted);
  margin-bottom: 20px;
}

.lang-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 22px;
}

.lang-option {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.07);
  background: rgba(255,255,255,0.04);
  cursor: pointer;
  transition: all 0.2s;
  font-size: 13px;
  color: #ccc;
  user-select: none;
}
.lang-option:hover {
  background: rgba(0,217,255,0.08);
  border-color: rgba(0,217,255,0.3);
  color: #fff;
}
.lang-option.selected {
  background: rgba(0,217,255,0.14);
  border-color: var(--accent);
  color: var(--accent);
  font-weight: 700;
}

.lang-option .flag { font-size: 20px; }

.modal-actions {
  display: flex;
  gap: 12px;
}

.btn-translate {
  flex: 1;
  padding: 12px;
  border-radius: 12px;
  border: none;
  background: linear-gradient(135deg, #00d9ff, #0099cc);
  color: #000;
  font-weight: 800;
  font-size: 14px;
  cursor: pointer;
  transition: 0.2s;
}
.btn-translate:hover { opacity: 0.88; transform: translateY(-1px); }
.btn-translate:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

.btn-close-modal {
  padding: 12px 18px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.05);
  color: #aaa;
  font-size: 14px;
  cursor: pointer;
  transition: 0.2s;
}
.btn-close-modal:hover { background: rgba(255,255,255,0.1); color: #fff; }

/* Translate button inline */
.translate-trigger {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 12px;
  border-radius: 20px;
  border: 1px solid rgba(0,217,255,0.35);
  background: rgba(0,217,255,0.08);
  color: var(--accent);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: 0.2s;
  margin-left: auto;
}
.translate-trigger:hover {
  background: rgba(0,217,255,0.16);
  box-shadow: 0 0 14px rgba(0,217,255,0.2);
}

/* Toast */
#tx-toast {
  position: fixed;
  bottom: 32px;
  right: 32px;
  padding: 13px 22px;
  border-radius: 12px;
  font-size: 13px;
  font-weight: 600;
  z-index: 99999;
  opacity: 0;
  transform: translateY(20px);
  transition: all 0.3s;
  pointer-events: none;
}
#tx-toast.show {
  opacity: 1;
  transform: translateY(0);
}
#tx-toast.success {
  background: rgba(34,217,138,0.15);
  border: 1px solid rgba(34,217,138,0.4);
  color: #22d98a;
}
#tx-toast.error {
  background: rgba(255,75,110,0.15);
  border: 1px solid rgba(255,75,110,0.4);
  color: #ff4b6e;
}

/* Spinner */
.tx-spinner {
  display: inline-block;
  width: 14px; height: 14px;
  border: 2px solid rgba(0,0,0,0.2);
  border-top-color: #000;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  vertical-align: middle;
  margin-right: 6px;
}
@keyframes spin { to { transform: rotate(360deg); } }
</style>
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar">
  <a class="nav-logo" href="/dashboard">🛡 TRUTH-X<span>-DETECTOR</span></a>
  <div class="nav-menu">
    <a href="/dashboard">Dashboard</a>
    <a href="/image_detector">Analyze Image</a>
    <a href="/analyzer" class="active">Message Scan</a>
    <a href="/tools">Tools</a>
    <a href="/settings">Settings</a>
    <a href="/logout" class="logout-btn">Logout</a>
  </div>
</nav>

<div class="page-wrap">

  <div style="margin-bottom:24px;">
    <h1 style="font-size:26px;font-weight:800;color:#fff;">🔎 Message Scam Analyzer</h1>
    <p style="color:var(--muted);font-size:14px;margin-top:4px;">Paste any message to check if it's a scam, phishing attempt or safe</p>
  </div>

  <div class="analyzer-grid">

    <!-- LEFT: Input + Results -->
    <div style="display:flex;flex-direction:column;gap:20px;">

      <div class="glass-card">
        <div class="section-title"><span class="dot"></span> Enter Message</div>
        <form method="POST">
          <div class="form-group">
            <textarea name="content" placeholder="Paste the suspicious message here...">{% if text %}{{ text }}{% endif %}</textarea>
          </div>
          <button class="btn btn-primary btn-full" type="submit" style="font-size:15px;padding:13px;">
            🔍 Analyze Message
          </button>
        </form>
      </div>

      {% if result %}
      <div class="glass-card anim-fadein">
        <!-- Result Header with Translate button -->
        <div class="section-title" style="display:flex;align-items:center;">
          <span class="dot"></span>&nbsp; Detection Result
          <button class="translate-trigger" onclick="openLangModal()" title="Translate results to another language">
            🌐 Translate Result
          </button>
        </div>

        {% if "SAFE" in result %}
          <div class="result-safe" id="tx-result">{{ result }}</div>
        {% elif "FAKE" in result %}
          <div class="result-warn" id="tx-result">{{ result }}</div>
        {% else %}
          <div class="result-scam" id="tx-result">{{ result }}</div>
        {% endif %}

        <div style="margin-top:24px;">
          <div class="section-title" style="font-size:15px;margin-bottom:12px;"><span class="dot"></span> Risk Indicators</div>

          {% if risky_words %}
            <div id="tx-risk-container" style="margin-bottom:16px;">
              {% for word in risky_words %}
                <span class="word-tag" data-original="⚠ {{ word }}">⚠ {{ word }}</span>
              {% endfor %}
            </div>
          {% else %}
            <p id="tx-no-risk" style="color:var(--muted);font-size:13px;margin-bottom:16px;">No risky keywords found</p>
          {% endif %}

          <div class="section-title" style="font-size:15px;margin-bottom:12px;"><span class="dot"></span> Pattern Warnings</div>
          {% if grammar_warnings %}
            <div id="tx-warn-container">
              {% for g in grammar_warnings %}
                <span class="warn-tag" data-original="📋 {{ g }}">📋 {{ g }}</span>
              {% endfor %}
            </div>
          {% else %}
            <p id="tx-no-warn" style="color:var(--muted);font-size:13px;">No suspicious patterns detected</p>
          {% endif %}
        </div>
      </div>
      {% endif %}

    </div>

    <!-- RIGHT: Score Panel -->
    <div style="display:flex;flex-direction:column;gap:20px;">

      {% if result %}
      <div class="glass-card anim-fadein">
        <div class="section-title"><span class="dot"></span> Scam Probability</div>

        <div class="chart-box">
          <canvas id="resultChart"></canvas>
        </div>

        <div class="pie-label">
          <div><span class="pie-dot" style="background:var(--red);"></span>Risk: <strong>{{ scam_percentage }}%</strong></div>
          <div><span class="pie-dot" style="background:var(--green);"></span>Safe: <strong>{{ safe_percentage }}%</strong></div>
        </div>

        <div style="margin-top:20px;">
          <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px;">
            <span style="color:var(--muted);">Scam Risk Score</span>
            <strong>{{ scam_percentage }}%</strong>
          </div>
          <div class="prog-track">
            <div class="prog-fill" style="width:{{ scam_percentage }}%;background:{% if scam_percentage >= 65 %}linear-gradient(90deg,#c0392b,#e74c3c){% elif scam_percentage >= 35 %}linear-gradient(90deg,#d4ac0d,#f5c518){% else %}linear-gradient(90deg,#16a085,#22d98a){% endif %};"></div>
          </div>
        </div>
      </div>
      {% endif %}

      <div class="glass-card">
        <div class="section-title"><span class="dot"></span> How It Works</div>
        <div style="display:flex;flex-direction:column;gap:10px;font-size:13px;color:var(--muted);">
          <div>🔑 <strong style="color:#fff;">Keyword Detection</strong> — scans for known scam phrases</div>
          <div>🔗 <strong style="color:#fff;">URL Analysis</strong> — checks for fake/typo links</div>
          <div>📋 <strong style="color:#fff;">Pattern Matching</strong> — detects phishing patterns</div>
          <div>🤖 <strong style="color:#fff;">AI Scoring</strong> — calculates combined risk score</div>
        </div>
      </div>

    </div>

  </div>

</div>

<!-- ═══════════════════════════════════ -->
<!--        LANGUAGE MODAL POPUP        -->
<!-- ═══════════════════════════════════ -->
<div id="lang-modal-overlay" onclick="handleOverlayClick(event)">
  <div id="lang-modal">
    <h3>🌐 Translate Results</h3>
    <p>Select a language to translate the detection results</p>

    <div class="lang-grid">
      <div class="lang-option selected" data-lang="en" onclick="selectLang(this)">
        <span class="flag">🇬🇧</span> English
      </div>
      <div class="lang-option" data-lang="hi" onclick="selectLang(this)">
        <span class="flag">🇮🇳</span> Hindi
      </div>
      <div class="lang-option" data-lang="ur" onclick="selectLang(this)">
        <span class="flag">🇵🇰</span> Urdu
      </div>
      <div class="lang-option" data-lang="es" onclick="selectLang(this)">
        <span class="flag">🇪🇸</span> Spanish
      </div>
      <div class="lang-option" data-lang="fr" onclick="selectLang(this)">
        <span class="flag">🇫🇷</span> French
      </div>
      <div class="lang-option" data-lang="ar" onclick="selectLang(this)">
        <span class="flag">🇸🇦</span> Arabic
      </div>
      <div class="lang-option" data-lang="de" onclick="selectLang(this)">
        <span class="flag">🇩🇪</span> German
      </div>
      <div class="lang-option" data-lang="pt" onclick="selectLang(this)">
        <span class="flag">🇧🇷</span> Portuguese
      </div>
      <div class="lang-option" data-lang="ja" onclick="selectLang(this)">
        <span class="flag">🇯🇵</span> Japanese
      </div>
      <div class="lang-option" data-lang="ru" onclick="selectLang(this)">
        <span class="flag">🇷🇺</span> Russian
      </div>
      <div class="lang-option" data-lang="bn" onclick="selectLang(this)">
        <span class="flag">🇧🇩</span> Bengali
      </div>
      <div class="lang-option" data-lang="zh" onclick="selectLang(this)">
        <span class="flag">🇨🇳</span> Chinese
      </div>
    </div>

    <div class="modal-actions">
      <button class="btn-translate" id="tx-btn" onclick="doTranslate()">
        🌐 Translate
      </button>
      <button class="btn-close-modal" onclick="closeLangModal()">✕ Close</button>
    </div>
  </div>
</div>

<!-- Toast Notification -->
<div id="tx-toast"></div>

{% if result %}
<script>
/* ─── Chart ─── */
const ctx = document.getElementById('resultChart');
new Chart(ctx, {
  type: 'doughnut',
  data: {
    labels: ['Scam Risk', 'Safe'],
    datasets: [{
      data: [{{ scam_percentage }}, {{ safe_percentage }}],
      backgroundColor: ['#ff4b6e', '#22d98a'],
      borderColor: ['rgba(255,75,110,0.3)', 'rgba(34,217,138,0.3)'],
      borderWidth: 2
    }]
  },
  options: {
    cutout: '70%',
    plugins: { legend: { display: false } }
  }
});

{% if "FAKE" in result or "SCAM" in result %}
try {
  const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  const osc = audioCtx.createOscillator();
  const gain = audioCtx.createGain();
  osc.type = 'sawtooth';
  osc.frequency.setValueAtTime(200, audioCtx.currentTime);
  osc.frequency.exponentialRampToValueAtTime(60, audioCtx.currentTime + 0.5);
  gain.gain.setValueAtTime(0.3, audioCtx.currentTime);
  gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.6);
  osc.connect(gain);
  gain.connect(audioCtx.destination);
  osc.start();
  osc.stop(audioCtx.currentTime + 0.6);
} catch(e) {}
{% endif %}

/* ─── Language Modal Logic ─── */
let selectedLang = 'en';

function openLangModal() {
  document.getElementById('lang-modal-overlay').classList.add('active');
}

function closeLangModal() {
  document.getElementById('lang-modal-overlay').classList.remove('active');
}

function handleOverlayClick(e) {
  if (e.target === document.getElementById('lang-modal-overlay')) closeLangModal();
}

function selectLang(el) {
  document.querySelectorAll('.lang-option').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  selectedLang = el.dataset.lang;
}

/* MyMemory free translation API */
async function translateText(text, targetLang) {
  if (!text || !text.trim()) return text;
  const url = `https://api.mymemory.translated.net/get?q=${encodeURIComponent(text)}&langpair=en|${targetLang}`;
  try {
    const res = await fetch(url);
    const data = await res.json();
    if (data.responseStatus === 200) {
      return data.responseData.translatedText;
    }
  } catch(e) {}
  return text; // fallback: return original
}

async function doTranslate() {
  const btn = document.getElementById('tx-btn');

  if (selectedLang === 'en') {
    // Reset to originals
    restoreOriginals();
    closeLangModal();
    showToast('✅ Showing original English results', 'success');
    return;
  }

  // Show loading state
  btn.disabled = true;
  btn.innerHTML = `<span class="tx-spinner"></span> Translating...`;

  try {
    // 1. Translate main result
    const resultEl = document.getElementById('tx-result');
    if (resultEl) {
      if (!resultEl.dataset.original) resultEl.dataset.original = resultEl.textContent.trim();
      const translated = await translateText(resultEl.dataset.original, selectedLang);
      resultEl.textContent = translated;
    }

    // 2. Translate risk word tags
    const riskTags = document.querySelectorAll('#tx-risk-container .word-tag');
    for (const tag of riskTags) {
      const orig = tag.dataset.original || tag.textContent.trim();
      tag.dataset.original = orig;
      // Strip the ⚠ emoji for translation
      const cleanOrig = orig.replace('⚠ ', '').replace('⚠', '').trim();
      const translated = await translateText(cleanOrig, selectedLang);
      tag.textContent = '⚠ ' + translated;
    }

    // 3. Translate no-risk text if present
    const noRiskEl = document.getElementById('tx-no-risk');
    if (noRiskEl) {
      if (!noRiskEl.dataset.original) noRiskEl.dataset.original = noRiskEl.textContent.trim();
      noRiskEl.textContent = await translateText(noRiskEl.dataset.original, selectedLang);
    }

    // 4. Translate pattern warning tags
    const warnTags = document.querySelectorAll('#tx-warn-container .warn-tag');
    for (const tag of warnTags) {
      const orig = tag.dataset.original || tag.textContent.trim();
      tag.dataset.original = orig;
      const cleanOrig = orig.replace('📋 ', '').replace('📋', '').trim();
      const translated = await translateText(cleanOrig, selectedLang);
      tag.textContent = '📋 ' + translated;
    }

    // 5. Translate no-warn text if present
    const noWarnEl = document.getElementById('tx-no-warn');
    if (noWarnEl) {
      if (!noWarnEl.dataset.original) noWarnEl.dataset.original = noWarnEl.textContent.trim();
      noWarnEl.textContent = await translateText(noWarnEl.dataset.original, selectedLang);
    }

    const langName = document.querySelector('.lang-option.selected').textContent.trim();
    showToast(`✅ Results translated to ${langName}`, 'success');
    closeLangModal();

  } catch(err) {
    showToast('❌ Translation failed. Please try again.', 'error');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '🌐 Translate';
  }
}

function restoreOriginals() {
  const resultEl = document.getElementById('tx-result');
  if (resultEl && resultEl.dataset.original) resultEl.textContent = resultEl.dataset.original;

  document.querySelectorAll('#tx-risk-container .word-tag').forEach(tag => {
    if (tag.dataset.original) tag.textContent = tag.dataset.original;
  });
  document.querySelectorAll('#tx-warn-container .warn-tag').forEach(tag => {
    if (tag.dataset.original) tag.textContent = tag.dataset.original;
  });

  const noRisk = document.getElementById('tx-no-risk');
  if (noRisk && noRisk.dataset.original) noRisk.textContent = noRisk.dataset.original;

  const noWarn = document.getElementById('tx-no-warn');
  if (noWarn && noWarn.dataset.original) noWarn.textContent = noWarn.dataset.original;
}

function showToast(msg, type) {
  const t = document.getElementById('tx-toast');
  t.textContent = msg;
  t.className = `show ${type}`;
  setTimeout(() => { t.className = ''; }, 3500);
}

// Keyboard: Escape closes modal
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeLangModal();
});
</script>
{% endif %}

</body>
</html>
